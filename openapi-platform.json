{
  "openapi": "3.0.0",
  "info": {
    "title": "1Club Platform API",
    "version": "1.0.0",
    "description": "The 1Club Platform API lets you programmatically access and manage your organization's data.\n\n## Authentication\n\nAll requests require a customer API key passed as a Bearer token:\n\n```\nAuthorization: Bearer 1club_sk_live_...\n```\n\nGenerate API keys from the admin portal under **Settings > API Tokens**.\nThe key is tied to your organization — all responses are scoped to your org's data.\n\n## Rate Limiting\n\n- **100 requests per minute** per API key\n- When exceeded, the API returns `429 Too Many Requests` with a `Retry-After` header\n- Rate limit headers are included in every response:\n  - `X-RateLimit-Limit` — max requests per window\n  - `X-RateLimit-Remaining` — requests remaining\n  - `X-RateLimit-Reset` — seconds until the window resets\n\n## Errors\n\n| Status | Meaning |\n|--------|---------|\n| `400` | Invalid request parameters |\n| `401` | Missing or invalid API key |\n| `404` | Resource not found (or doesn't belong to your organization) |\n| `429` | Rate limit exceeded |\n| `500` | Internal server error |",
    "contact": {
      "name": "1Club API Support",
      "email": "support@1club.ai"
    }
  },
  "servers": [
    {
      "url": "http://localhost:8000",
      "description": "Development server"
    },
    {
      "url": "https://api.1club.ai",
      "description": "Production API"
    }
  ],
  "components": {
    "securitySchemes": {
      "customerApiAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Customer API key obtained from the admin portal (e.g. 1club_sk_live_...)"
      }
    },
    "schemas": {
      "PlatformContact": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string", "nullable": true },
          "email": { "type": "string", "nullable": true },
          "phone": { "type": "string", "nullable": true },
          "profileImage": { "type": "string", "nullable": true },
          "address": { "type": "string", "nullable": true }
        }
      },
      "PlatformInstructor": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "contacts": { "$ref": "#/components/schemas/PlatformContact" }
        }
      },
      "PlatformArea": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "area_types": {
            "type": "object",
            "nullable": true,
            "properties": {
              "sports": { "type": "string", "nullable": true },
              "name": { "type": "string" }
            }
          }
        }
      },
      "PlatformClass": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "startTime": { "type": "string", "format": "date-time" },
          "endTime": { "type": "string", "format": "date-time" },
          "price": { "type": "number", "nullable": true },
          "isFree": { "type": "boolean" },
          "instructors": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PlatformInstructor" }
          }
        }
      },
      "PlatformClub": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "slug": { "type": "string" },
          "address": { "type": "string", "nullable": true },
          "phone": { "type": "string", "nullable": true },
          "email": { "type": "string", "nullable": true }
        }
      },
      "PlatformPaymentMethod": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" }
        }
      },
      "PlatformMembership": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "usesRemaining": { "type": "integer", "nullable": true },
          "maxUses": { "type": "integer", "nullable": true },
          "status": { "type": "string" },
          "plans": {
            "type": "object",
            "nullable": true,
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" }
            }
          }
        }
      },
      "PlatformTransaction": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "amount": { "type": "number" },
          "taxAmount": { "type": "number", "nullable": true },
          "totalAmount": { "type": "number" },
          "currency": { "type": "string" },
          "paymentStatus": { "type": "string" },
          "transactionType": { "type": "string" },
          "tax_rates": {
            "type": "object",
            "nullable": true,
            "properties": {
              "id": { "type": "integer" },
              "name": { "type": "string" },
              "rate": { "type": "number" },
              "description": { "type": "string", "nullable": true }
            }
          }
        }
      },
      "PlatformBooking": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "userId": { "type": "integer", "nullable": true },
          "sport": { "type": "string", "nullable": true },
          "startTime": { "type": "string", "format": "date-time" },
          "endTime": { "type": "string", "format": "date-time" },
          "totalPrice": { "type": "number" },
          "status": {
            "type": "string",
            "enum": ["pending", "confirmed", "cancelled"]
          },
          "notes": { "type": "string", "nullable": true },
          "createdAt": { "type": "string", "format": "date-time" },
          "playerEmails": { "type": "array", "items": { "type": "string" }, "nullable": true },
          "entranceMethod": { "type": "string", "nullable": true },
          "preferredPaymentMethod": {
            "nullable": true,
            "$ref": "#/components/schemas/PlatformPaymentMethod"
          },
          "areas": {
            "nullable": true,
            "$ref": "#/components/schemas/PlatformArea"
          },
          "classes": {
            "nullable": true,
            "$ref": "#/components/schemas/PlatformClass"
          },
          "instructors": {
            "nullable": true,
            "$ref": "#/components/schemas/PlatformInstructor"
          },
          "clubs": {
            "nullable": true,
            "$ref": "#/components/schemas/PlatformClub"
          },
          "contacts": {
            "nullable": true,
            "$ref": "#/components/schemas/PlatformContact"
          },
          "organizations": {
            "type": "object",
            "properties": {
              "currency": { "type": "string" }
            }
          },
          "memberships": {
            "nullable": true,
            "$ref": "#/components/schemas/PlatformMembership"
          },
          "transactions": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/PlatformTransaction" }
          },
          "duration": {
            "type": "number",
            "description": "Booking duration in hours (derived)"
          },
          "amountDue": {
            "type": "number",
            "description": "Outstanding amount due (derived)"
          },
          "isPast": {
            "type": "boolean",
            "description": "Whether the booking is in the past (derived)"
          },
          "paymentStatus": {
            "type": "string",
            "description": "Payment status from the latest transaction (derived)"
          },
          "paidStatus": {
            "type": "string",
            "enum": ["paid", "unpaid", "not_required"],
            "description": "Simplified paid status (derived)"
          }
        }
      }
    }
  },
  "security": [
    {
      "customerApiAuth": []
    }
  ],
  "paths": {
    "/v1/platform/bookings": {
      "get": {
        "summary": "List bookings for the organization",
        "description": "Returns bookings for the organization associated with the API token. Supports filtering by club, area, class, instructor, contact, status, and date range. Cancelled bookings are excluded by default.\n",
        "tags": [
          "Bookings"
        ],
        "security": [
          {
            "customerApiAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "clubId",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by club ID"
          },
          {
            "in": "query",
            "name": "areaId",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by area ID"
          },
          {
            "in": "query",
            "name": "classId",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by class ID"
          },
          {
            "in": "query",
            "name": "instructorId",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by instructor ID"
          },
          {
            "in": "query",
            "name": "contactId",
            "schema": {
              "type": "integer"
            },
            "description": "Filter by contact ID"
          },
          {
            "in": "query",
            "name": "status",
            "schema": {
              "type": "string",
              "enum": ["pending", "confirmed", "cancelled"]
            },
            "description": "Filter by booking status"
          },
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter bookings starting from this date"
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter bookings ending before this date"
          },
          {
            "in": "query",
            "name": "includeCancelled",
            "schema": {
              "type": "boolean"
            },
            "description": "Include cancelled bookings (excluded by default)"
          }
        ],
        "responses": {
          "200": {
            "description": "List of bookings with details",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/PlatformBooking"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key"
          },
          "403": {
            "description": "Missing required scope (bookings:read)"
          }
        }
      }
    },
    "/v1/platform/bookings/{id}": {
      "get": {
        "summary": "Get a booking by ID",
        "description": "Returns a single booking with full details. The booking must belong to the organization associated with the API token.\n",
        "tags": [
          "Bookings"
        ],
        "security": [
          {
            "customerApiAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Booking ID"
          }
        ],
        "responses": {
          "200": {
            "description": "Booking details",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlatformBooking"
                }
              }
            }
          },
          "400": {
            "description": "Invalid booking ID"
          },
          "404": {
            "description": "Booking not found"
          }
        }
      }
    },
    "/v1/platform/classes": {
      "get": {
        "summary": "List classes for the organization",
        "description": "Returns all classes for the organization associated with the API token.\n",
        "tags": [
          "Classes"
        ],
        "security": [
          {
            "customerApiAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "startDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter classes starting from this date"
          },
          {
            "in": "query",
            "name": "endDate",
            "schema": {
              "type": "string",
              "format": "date-time"
            },
            "description": "Filter classes ending before this date"
          },
          {
            "in": "query",
            "name": "locale",
            "schema": {
              "type": "string"
            },
            "description": "Locale for translations (e.g. \"en\", \"es\")"
          }
        ],
        "responses": {
          "200": {
            "description": "List of classes"
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        }
      }
    },
    "/v1/platform/classes/{id}": {
      "get": {
        "summary": "Get a class by ID",
        "description": "Returns a single class. The class must belong to the organization associated with the API token.\n",
        "tags": [
          "Classes"
        ],
        "security": [
          {
            "customerApiAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "id",
            "required": true,
            "schema": {
              "type": "integer"
            },
            "description": "Class ID"
          },
          {
            "in": "query",
            "name": "locale",
            "schema": {
              "type": "string"
            },
            "description": "Locale for translations"
          }
        ],
        "responses": {
          "200": {
            "description": "Class details"
          },
          "404": {
            "description": "Class not found"
          }
        }
      }
    },
    "/v1/platform/clubs/{slug}": {
      "get": {
        "summary": "Get club details by slug",
        "description": "Returns club details including amenities, rating, and images. The club must belong to the organization associated with the API token.\n",
        "tags": [
          "Clubs"
        ],
        "security": [
          {
            "customerApiAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "slug",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Club slug"
          },
          {
            "in": "query",
            "name": "locale",
            "schema": {
              "type": "string"
            },
            "description": "Locale for amenity translations"
          }
        ],
        "responses": {
          "200": {
            "description": "Club details"
          },
          "404": {
            "description": "Club not found"
          }
        }
      }
    },
    "/v1/platform/content": {
      "get": {
        "summary": "List published content",
        "description": "Returns published content for the organization. Optionally filter by type.\n",
        "tags": [
          "Content"
        ],
        "security": [
          {
            "customerApiAuth": []
          }
        ],
        "parameters": [
          {
            "in": "query",
            "name": "type",
            "schema": {
              "type": "string",
              "enum": [
                "faq",
                "post",
                "announcement",
                "document",
                "rich-text"
              ]
            },
            "description": "Filter by content type"
          },
          {
            "in": "query",
            "name": "locale",
            "schema": {
              "type": "string"
            },
            "description": "Locale for content resolution"
          }
        ],
        "responses": {
          "200": {
            "description": "List of published content"
          },
          "401": {
            "description": "Invalid or missing API key"
          }
        }
      }
    },
    "/v1/platform/content/{slug}": {
      "get": {
        "summary": "Get content by slug",
        "description": "Returns a single published content item by slug.\n",
        "tags": [
          "Content"
        ],
        "security": [
          {
            "customerApiAuth": []
          }
        ],
        "parameters": [
          {
            "in": "path",
            "name": "slug",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Content slug"
          },
          {
            "in": "query",
            "name": "locale",
            "schema": {
              "type": "string"
            },
            "description": "Locale for content resolution"
          }
        ],
        "responses": {
          "200": {
            "description": "Content item"
          },
          "404": {
            "description": "Content not found"
          }
        }
      }
    }
  },
  "tags": []
}
